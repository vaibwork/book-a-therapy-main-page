# Main_Page (Portal Hub) — portal link template.
# Copy to .env.production (or set in your host's build env). Vite bakes VITE_* in at build time.
# Leave unset for local dev — the app falls back to the correct localhost ports.

VITE_CUSTOMER_URL=https://bookatherapy.com
VITE_PRACTITIONER_URL=https://practitioner.bookatherapy.com
VITE_CLINIC_URL=https://clinic.bookatherapy.com
